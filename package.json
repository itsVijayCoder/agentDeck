{
  "name": "openfusion",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm --filter @openfusion/web dev",
    "build": "pnpm --filter @openfusion/web build",
    "start": "pnpm --filter @openfusion/web start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter @openfusion/web test:watch",
    "test:e2e": "pnpm --filter @openfusion/web test:e2e",
    "build:packages": "pnpm -r --filter './packages/*' build",
    "deploy": "pnpm --filter @openfusion/web deploy",
    "upload": "pnpm --filter @openfusion/web upload",
    "preview": "pnpm --filter @openfusion/web preview",
    "cf-typegen": "pnpm --filter @openfusion/web cf-typegen"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@cloudflare/workers-types": "^4.20260628.0",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "typescript": "^5.7.4",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
