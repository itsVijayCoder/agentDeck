# AgentDeck web local development secrets
# Copy to .dev.vars from apps/web when running Wrangler or OpenNext commands there.
# .dev.vars is gitignored.

# Cookie signing secret for the Phase 02 BFF.
AGENTDECK_SESSION_SECRET=

# Cloudflare AI Gateway (Phase 10)
CLOUDFLARE_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_GATEWAY_ID=default
AGENTDECK_AI_GATEWAY_MODE=cloudflare-rest
AGENTDECK_AI_DLP_MODE=off

# Bridge pairing secret (Phase 04)
AGENTDECK_BRIDGE_TOKEN=
