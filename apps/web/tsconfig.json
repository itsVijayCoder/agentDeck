{
	"extends": "@openfusion/config/tsconfig/react.json",
	"compilerOptions": {
		"allowJs": false,
		"noEmit": true,
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": [
			"./cloudflare-env.d.ts",
			"node"
		]
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", ".next/dev/types/**/*.ts"],
	"exclude": [".next", ".open-next", ".wrangler", "coverage", "dist", "node_modules", "test-results"]
}
