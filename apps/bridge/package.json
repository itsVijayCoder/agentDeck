{
  "name": "@agentdeck/bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "agentdeck-bridge": "./dist/main.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@agentdeck/bridge-protocol": "workspace:*",
    "@agentdeck/core": "workspace:*",
    "@agentdeck/policy": "workspace:*",
    "commander": "^12.1.0",
    "execa": "^9.6.0",
    "node-pty": "^1.0.0",
    "simple-git": "^3.28.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@agentdeck/config": "workspace:*",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "tsx": "^4.20.6",
    "typescript": "^5.7.4",
    "vitest": "^4.1.9"
  }
}
